// Flashbot Arbitrage Bot with Safe Withdraw Feature
const express = require('express');
const ethers = require('ethers');
const app = express();
const PORT = process.env.PORT || 8080;

app.use(express.json());

const WALLET_ADDRESS = process.env.WALLET_ADDRESS; 
const RPC_URL = process.env.RPC_URL;

if (!WALLET_ADDRESS || !RPC_URL) {
  console.warn("⚠️ WALLET_ADDRESS or RPC_URL is not set. Withdrawals won't work.");
}

const provider = new ethers.JsonRpcProvider(RPC_URL);

app.get('/', (req, res) => {
  res.send('Flashbot is running 🚀');
});

app.get('/balance', async (req, res) => {
  if (!WALLET_ADDRESS) return res.status(400).send('Wallet address not set');
  try {
    const balance = await provider.getBalance(WALLET_ADDRESS);
    res.json({ balance: ethers.formatEther(balance) });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

app.post('/withdraw', (req, res) => {
  const { amount, to } = req.body;
  if (!amount || !to) return res.status(400).send('Provide amount and recipient');
  console.log(`Request to withdraw ${amount} ETH to ${to} received.`);
  res.json({ status: 'success', message: `Withdraw request logged for ${amount} ETH to ${to}` });
});

app.listen(PORT, () => {
  console.log(`Flashbot listening on port ${PORT}`);
});
{
  "name": "flashbot",
  "version": "1.0.0",
  "description": "Flashbot arbitrage bot for Fly.io deployment",
  "main": "index.js",
  "scripts": {
    "start": "node index.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ethers": "^6.6.2"
  }
}# Stage 1: Build
FROM node:18 AS build
WORKDIR /usr/src/app
COPY package*.json ./
RUN npm install
COPY . .

# Stage 2: Production
FROM node:18
WORKDIR /usr/src/app
COPY --from=build /usr/src/app/node_modules ./node_modules
COPY --from=build /usr/src/app/package*.json ./
COPY --from=build /usr/src/app .
ENV PORT=8080
EXPOSE $PORT
USER node
CMD [ "node", "index.js" ]
